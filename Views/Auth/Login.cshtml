@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4>
                        <i class="bi bi-box-arrow-in-right me-2"></i>SaigonRide — <span data-i18n="login.title">Login</span>
                    </h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger d-flex align-items-center gap-2">
                            <i class="bi bi-x-circle-fill"></i>
                            @ViewBag.Error
                        </div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill"></i>
                            @TempData["Success"]
                        </div>
                    }

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="bi bi-envelope-fill me-1"></i><span data-i18n="login.email">Email</span>
                            </label>
                            <input type="email" name="email"
                                   class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="bi bi-lock-fill me-1"></i><span data-i18n="login.password">Password</span>
                            </label>
                            <input type="password" name="password"
                                   class="form-control" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-box-arrow-in-right me-2"></i><span data-i18n="login.btn">Login</span>
                        </button>
                    </form>

                    <hr />
                    <p class="text-center">
                        <span data-i18n="login.noaccount">Don't have an account?</span>
                        <a asp-controller="Auth" asp-action="Register" data-i18n="login.register">Register here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
