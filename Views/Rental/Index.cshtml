@model IEnumerable<SaigonRide.Models.Rental>

@{
    ViewData["Title"] = "Danh sách Rental";
}

<h1 data-i18n="rental.index.title">Danh sách Rental</h1>

@if (TempData["Success"] != null)
{
    <div style="background:#d4edda; padding:10px; margin-bottom:10px;
        border-radius:5px; color:#155724;">
        ✅ @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div style="background:#f8d7da; padding:10px; margin-bottom:10px;
        border-radius:5px; color:#721c24;">
        ❌ @TempData["Error"]
    </div>
}

<table class="table">
    <thead>
        <tr>
            <th>Rental ID</th>
            <th data-i18n="rental.col.type">Loại xe</th>
            <th data-i18n="rental.col.start">Giờ bắt đầu</th>
            <th data-i18n="rental.col.end">Giờ kết thúc</th>
            <th data-i18n="rental.col.fare">Tổng tiền</th>
            <th data-i18n="rental.col.discount">Giảm giá</th>
            <th data-i18n="rental.col.status">Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RentalID</td>
                <td>@(item.Vehicle?.Type ?? "N/A")</td>
                <td>@item.StartTime.ToString("HH:mm dd/MM/yyyy")</td>
                <td>@(item.EndTime?.ToString("HH:mm dd/MM/yyyy") ?? "Đang thuê")</td>
                <td>@(item.TotalFare.HasValue ? $"{item.TotalFare:N0} VND" : "-")</td>
                <td>@(item.Discount > 0 ? $"{item.Discount:N0} VND" : "-")</td>
                <td>
                    @if (item.Status == "Active")
                    {
                        <span style="color:orange; font-weight:bold" data-i18n="rental.status.active">🟡 Đang thuê</span>
                    }
                    else
                    {
                        <span style="color:green" data-i18n="rental.status.done">✅ Hoàn thành</span>
                    }
                </td>
                <td>
                    @if (item.Status == "Active")
                    {
                        <a asp-action="ReturnVehicle" asp-route-rentalId="@item.RentalID"
                           style="color:red; font-weight:bold" data-i18n="rental.return.btn">🔴 Trả xe</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
