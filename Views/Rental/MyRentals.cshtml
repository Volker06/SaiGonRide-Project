@model IEnumerable<SaigonRide.Models.Rental>

@{
    ViewData["Title"] = "My Rentals";
}

<div class="container-fluid px-4 py-3">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">
                <i class="bi bi-clock-history me-2"></i>My Rental History
            </h2>
            <small class="text-muted">All your rental transactions</small>
        </div>
        <a asp-controller="Station" asp-action="SelectStation" class="btn btn-primary">
            <i class="bi bi-bicycle me-2"></i>Rent a Vehicle
        </a>
    </div>

    <hr class="mb-4" />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5">
            <i class="bi bi-inbox" style="font-size:3rem; color:#6C757D;"></i>
            <h5 class="mt-3 text-muted">No rental history yet</h5>
            <p class="text-muted small">Start your first ride today!</p>
            <a asp-controller="Station" asp-action="SelectStation"
               class="btn btn-primary mx-auto" style="width:200px;">
                <i class="bi bi-bicycle me-2"></i>Rent a Vehicle
            </a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3 text-muted small">#</th>
                            <th class="py-3 text-muted small">VEHICLE</th>
                            <th class="py-3 text-muted small">START TIME</th>
                            <th class="py-3 text-muted small">END TIME</th>
                            <th class="py-3 text-muted small">FARE</th>
                            <th class="py-3 text-muted small">DISCOUNT</th>
                            <th class="py-3 text-muted small">STATUS</th>
                            <th class="py-3 text-muted small">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 text-muted">
                                    #@item.RentalID
                                </td>
                                <td class="py-3 fw-bold">
                                    @if (item.Vehicle?.Type == "E-Scooter")
                                    {
                                        <i class="bi bi-scooter me-1"
                                           style="color:#F5A623;"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-bicycle me-1"
                                           style="color:#1A3C8F;"></i>
                                    }
                                    @(item.Vehicle?.Type ?? "N/A")
                                </td>
                                <td class="py-3">
                                    @item.StartTime.ToString("HH:mm dd/MM/yyyy")
                                </td>
                                <td class="py-3">
                                    @if (item.EndTime.HasValue)
                                    {
                                        @item.EndTime.Value.ToString("HH:mm dd/MM/yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-warning fw-bold">Active</span>
                                    }
                                </td>
                                <td class="py-3 fw-bold text-success">
                                    @(item.TotalFare.HasValue
                                        ? item.TotalFare.Value.ToString("N0") + " VND"
                                        : "-")
                                </td>
                                <td class="py-3 text-success">
                                    @(item.Discount > 0
                                        ? "-" + item.Discount.ToString("N0") + " VND"
                                        : "-")
                                </td>
                                <td class="py-3">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-clock me-1"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>
                                            Completed
                                        </span>
                                    }
                                </td>
                                <td class="py-3">
                                    @if (item.Status == "Active")
                                    {
                                        <a asp-controller="Rental"
                                               asp-action="Return"
                                               asp-route-rentalId="@item.RentalID"
                                               class="btn btn-sm btn-danger">
                                            <i class="bi bi-arrow-return-left me-1"></i>
                                            Return
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>