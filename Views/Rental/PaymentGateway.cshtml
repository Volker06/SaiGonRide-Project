@{
    ViewData["Title"] = "Thanh toán";
    var method = ViewBag.Method as string;
    var amount = (double)ViewBag.Amount;
    var rentalId = (int)ViewBag.RentalId;
}

<div class="container py-4 text-center" style="max-width: 500px;">

    @if (method == "MoMo")
    {
        <div class="mb-3">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center"
                 style="width:80px; height:80px; background:#ae2070;">
                <i class="bi bi-phone-fill text-white" style="font-size:2rem;"></i>
            </div>
        </div>
        <h3 class="fw-bold" style="color:#ae2070;">Thanh toán MoMo</h3>
    }
    else
    {
        <div class="mb-3">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center"
                 style="width:80px; height:80px; background:#0066cc;">
                <i class="bi bi-credit-card-fill text-white" style="font-size:2rem;"></i>
            </div>
        </div>
        <h3 class="fw-bold" style="color:#0066cc;">Thanh toán VNPay</h3>
    }

    <p class="text-muted mb-4">Quét mã QR để thanh toán</p>

    <!-- QR Code giả -->
    <div class="card shadow border-0 rounded-4 mb-4 mx-auto" style="max-width:300px;">
        <div class="card-body p-4">
            <div class="bg-light rounded-3 p-4 mb-3"
                 style="width:200px; height:200px; margin:auto;
                display:flex; align-items:center; justify-content:center;">
                <i class="bi bi-qr-code" style="font-size:8rem; color:#333;"></i>
            </div>
            <p class="fw-bold fs-5 text-success mb-0">
                @amount.ToString("N0") VND
            </p>
            <small class="text-muted">Rental #@rentalId</small>
        </div>
    </div>

    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        Mã QR sẽ hết hạn sau <strong id="countdown">60</strong> giây
    </div>

    <div class="d-flex gap-3">
        <a href="/Rental/PaymentSuccess?rentalId=@rentalId&method=@method&amount=@amount"
           class="btn btn-success btn-lg flex-fill">
            <i class="bi bi-check-circle me-2"></i>
            Thanh toán thành công
        </a>

        <form method="post" action="/Rental/PaymentFailed" class="flex-fill">
            @Html.AntiForgeryToken()
            <input type="hidden" name="rentalId" value="@rentalId" />
            <input type="hidden" name="method" value="@method" />
            <input type="hidden" name="amount" value="@amount" />
            <button type="submit" class="btn btn-danger btn-lg w-100">
                <i class="bi bi-x-circle me-2"></i>
                Thất bại
            </button>
        </form>
    </div>
</div>

<script>
    let seconds = 60;
    const countdown = document.getElementById('countdown');
    const timer = setInterval(() => {
        seconds--;
        countdown.textContent = seconds;
        if (seconds <= 0) {
            clearInterval(timer);
            document.querySelector('form[action="/Rental/PaymentFailed"]').submit();
        }
    }, 1000);
</script>