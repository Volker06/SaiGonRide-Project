@{
    ViewData["Title"] = "Thanh toán thành công";
    var method = ViewBag.Method as string;
    var amount = (double)ViewBag.Amount;
}

<div class="container py-4 text-center" style="max-width: 500px;">

    <div class="mb-4">
        <div class="rounded-circle d-inline-flex align-items-center justify-content-center bg-success"
             style="width:100px; height:100px;">
            <i class="bi bi-check-lg text-white" style="font-size:3rem;"></i>
        </div>
    </div>

    <h2 class="fw-bold text-success mb-2">Thanh toán thành công!</h2>
    <p class="text-muted mb-4">Cảm ơn bạn đã sử dụng SaigonRide</p>

    <div class="card shadow border-0 rounded-4 mb-4 text-start">
        <div class="card-body p-4">
            <table class="table table-borderless mb-0">
                <tr>
                    <td><strong>Phương thức:</strong></td>
                    <td>
                        @if (method == "Cash")
                        {
                            <i class="bi bi-cash-coin me-1 text-success"></i>
                        }
                        else if (method == "MoMo")
                        {
                            <i class="bi bi-phone me-1" style="color:#ae2070;"></i>
                        }
                        else
                        {
                            <i class="bi bi-credit-card me-1" style="color:#0066cc;"></i>
                        }
                        @method
                    </td>
                </tr>
                <tr>
                    <td><strong>Số tiền:</strong></td>
                    <td class="fw-bold text-success fs-5">
                        @amount.ToString("N0") VND
                    </td>
                </tr>
                <tr>
                    <td><strong>Trạng thái:</strong></td>
                    <td>
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle me-1"></i>Thành công
                        </span>
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg w-100">
        <i class="bi bi-house-fill me-2"></i>Back to Home
    </a>
</div>