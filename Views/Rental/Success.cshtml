@model SaigonRide.Models.Rental

@{
    ViewData["Title"] = "Thuê xe thành công";
}

<div class="container text-center" style="max-width: 600px;">

    <div class="mb-4">
        <i class="bi bi-patch-check-fill text-success" style="font-size: 80px;"></i>
    </div>

    <h2 class="text-success mb-2">Thuê xe thành công!</h2>
    <p class="text-muted mb-4">
        Chúc bạn có chuyến đi vui vẻ!
    </p>

    <div class="card shadow border-0 rounded-4 mb-4 text-start">
        <div class="card-body p-4">
            <h5 class="mb-3">
                <i class="bi bi-receipt-cutoff text-primary me-2"></i>Thông tin chuyến đi
            </h5>
            <table class="table table-borderless">
                <tr>
                    <td><i class="bi bi-hash text-secondary me-2"></i><strong>Rental ID:</strong></td>
                    <td class="fw-bold text-primary">#@Model.RentalID</td>
                </tr>
                <tr>
                    <td><i class="bi bi-bicycle text-secondary me-2"></i><strong>Loại xe:</strong></td>
                    <td>@Model.Vehicle?.Type</td>
                </tr>
                <tr>
                    <td><i class="bi bi-geo-alt-fill text-secondary me-2"></i><strong>Trạm xuất phát:</strong></td>
                    <td>@(Model.Vehicle?.Station?.StationName ?? "N/A")</td>
                </tr>
                <tr>
                    <td><i class="bi bi-clock-fill text-secondary me-2"></i><strong>Giờ bắt đầu:</strong></td>
                    <td class="text-success fw-bold">@Model.StartTime.ToString("HH:mm dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <td><i class="bi bi-cash-coin text-secondary me-2"></i><strong>Giá thuê:</strong></td>
                    <td>@Model.Vehicle?.PricePerMinute.ToString("N0") VND/phút</td>
                </tr>
            </table>
        </div>
    </div>

    <div class="alert alert-info d-flex align-items-start gap-2 text-start">
        <i class="bi bi-lightbulb-fill fs-5 mt-1"></i>
        <div>
            Giảm <strong>15%</strong> sẽ được áp dụng khi bạn trả xe về trạm đang có số xe dưới 20% sức chứa.
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-center">
        <a asp-controller="Home" asp-action="Index"
               class="btn btn-primary btn-lg flex-fill">
            <i class="bi bi-house-fill me-2"></i>Back to Home
        </a>
        <a asp-controller="Rental" asp-action="MyRentals"
               class="btn btn-outline-secondary btn-lg flex-fill">
            <i class="bi bi-list-ul me-2"></i>Lịch sử thuê
        </a>
    </div>
</div>
