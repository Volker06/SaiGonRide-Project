@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SaigonRide</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SaigonRide.styles.css" asp-append-version="true" />
    <style>
        #lang-toggle-btn {
            font-size: 0.85rem;
            padding: 4px 12px;
            border-radius: 20px;
            border: 1.5px solid rgba(255,255,255,0.6);
            background: transparent;
            color: #fff;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s;
            white-space: nowrap;
        }
        #lang-toggle-btn:hover {
            background: rgba(255,255,255,0.15);
            border-color: #fff;
        }
        .lang-flag { font-size: 1rem; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
            <div class="container">
                <a class="navbar-brand fw-bold"
                       asp-controller="Home"
                       asp-action="Index">
                    <i class="bi bi-bicycle me-2"></i>SaigonRide
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-controller="Home"
                                   asp-action="Index">
                                <i class="bi bi-house me-1"></i><span data-i18n="nav.home">Home</span>
                            </a>
                        </li>

                        @if (Context.Session.GetString("UserType") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Vehicle"
                                       asp-action="Index">
                                    <i class="bi bi-bicycle me-1"></i><span data-i18n="nav.vehicles">Vehicles</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Station"
                                       asp-action="Index">
                                    <i class="bi bi-geo-alt me-1"></i><span data-i18n="nav.stations">Stations</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Report"
                                       asp-action="Index">
                                    <i class="bi bi-bar-chart me-1"></i><span data-i18n="nav.reports">Reports</span>
                                </a>
                            </li>
                        }
                        else if (Context.Session.GetString("UserType") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Station"
                                   asp-action="SelectStation">
                                    <i class="bi bi-bicycle me-1"></i><span data-i18n="nav.rent">Rent a Vehicle</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Rental"
                                   asp-action="MyRentals">
                                    <i class="bi bi-clock-history me-1"></i><span data-i18n="nav.myrentals">My Rentals</span>
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">
                        @if (Context.Session.GetString("UserType") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Auth"
                                       asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i><span data-i18n="nav.login">Login</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Auth"
                                       asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i><span data-i18n="nav.register">Register</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @Context.Session.GetString("FullName")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Auth"
                                       asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i><span data-i18n="nav.logout">Logout</span>
                                </a>
                            </li>
                        }

                        <!-- ★ Nút chuyển ngôn ngữ ★ -->
                        <li class="nav-item ms-1">
                            <button id="lang-toggle-btn" type="button" title="Switch language">
                                <span class="lang-flag">🇻🇳</span>
                                <span class="lang-label"> Tiếng Việt</span>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-3 text-center">
            <i class="bi bi-bicycle me-2"></i>
            &copy; <span data-i18n="footer.copy">2026 - SaigonRide</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
