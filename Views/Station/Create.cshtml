@model SaigonRide.Models.Station

@{
    ViewData["Title"] = "Create Station";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0" data-i18n="station.create.title">Add New Station</h3>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="StationName" class="form-label" data-i18n="station.create.name">Station Name</label>
                    <input asp-for="StationName"
                           class="form-control"
                           placeholder="Enter station name" />
                    <span asp-validation-for="StationName"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="form-label" data-i18n="station.create.location">Location</label>
                    <input asp-for="Location"
                           class="form-control"
                           placeholder="Enter station location" />
                    <span asp-validation-for="Location"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Capacity" class="form-label" data-i18n="station.create.capacity">Capacity</label>
                    <input asp-for="Capacity"
                           class="form-control"
                           placeholder="Enter station capacity" />
                    <span asp-validation-for="Capacity"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" data-i18n="station.create.inventory">Current Inventory</label>
                    <input class="form-control"
                           value="0"
                           readonly />
                    <small class="text-muted" data-i18n="station.create.hint">
                        Vehicles will be added automatically later.
                    </small>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success" data-i18n="station.create.btn">
                        Create Station
                    </button>

                    <a asp-action="Index" class="btn btn-secondary ms-2" data-i18n="station.create.back">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
