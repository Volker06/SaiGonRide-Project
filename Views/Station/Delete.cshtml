@model SaigonRide.Models.Station

@{
    ViewData["Title"] = "Delete Station";
}

<h2 class="mb-4"><i class="bi bi-trash3-fill text-danger me-2"></i> Delete Station</h2>

<div class="alert alert-danger d-flex align-items-start gap-2">
    <i class="bi bi-exclamation-triangle-fill fs-5 mt-1"></i>
    <div>
        Bạn có chắc muốn xóa trạm <strong>@Model.StationName</strong> không?
        @if (Model.Vehicles != null && Model.Vehicles.Any())
        {
            <br />
            <small>
                Trạm này có <strong>@Model.Vehicles.Count() xe</strong> —
                các xe sẽ bị bỏ liên kết khỏi trạm!
            </small>
        }
    </div>
</div>

<div class="card shadow-lg border-0 rounded-4" style="max-width: 500px;">
    <div class="card-body p-4">
        <table class="table table-borderless">
            <tr>
                <td><strong>Tên trạm:</strong></td>
                <td>@Model.StationName</td>
            </tr>
            <tr>
                <td><strong>Địa điểm:</strong></td>
                <td>@Model.Location</td>
            </tr>
            <tr>
                <td><strong>Số xe hiện có:</strong></td>
                <td>@Model.CurrentInventory / @Model.Capacity</td>
            </tr>
        </table>

        <form asp-action="Delete">
            <input type="hidden" asp-for="StationID" />
            <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-trash3 me-1"></i> Confirm Delete
            </button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">
                <i class="bi bi-arrow-left me-1"></i> Cancel
            </a>
        </form>
    </div>
</div>
