@model SaigonRide.Models.Vehicle

@{
    ViewData["Title"] = "Add New Vehicle";
}

<h2 class="mb-4">➕ <span data-i18n="vehicle.create.title">Add New Vehicle</span></h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">✅ @TempData["Success"]</div>
}

<div class="card shadow-lg border-0 rounded-4" style="max-width: 500px;">
    <div class="card-body p-4">
        <form asp-action="Create">

            <div class="mb-3">
                <label class="form-label">
                    <strong data-i18n="vehicle.create.type">Loại xe</strong>
                </label>
                <select name="Type" class="form-select" required
                        onchange="autoFillPrice(this.value)">
                    <option value="" data-i18n="vehicle.create.choose">-- Chọn loại xe --</option>
                    <option value="Standard Bike">🚲 Standard Bike</option>
                    <option value="E-Scooter">🛵 E-Scooter</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <strong data-i18n="vehicle.create.price">Giá thuê (VND/phút)</strong>
                </label>
                <input type="number" name="PricePerMinute" id="priceInput"
                       class="form-control" readonly
                       style="background:#f8f9fa;" />
                <small class="text-muted">@ViewBag.PriceHint</small>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <strong data-i18n="vehicle.create.station">Trạm</strong>
                </label>
                <select name="StationID" class="form-select" asp-items="ViewBag.StationID">
                    <option value="" data-i18n="vehicle.create.choose2">-- Chọn trạm --</option>
                </select>
            </div>

            <button type="submit" class="btn btn-success w-100">
                ➕ <span data-i18n="vehicle.create.btn">Add Vehicle</span>
            </button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">
                ⬅ <span data-i18n="vehicle.create.back">Back</span>
            </a>
        </form>
    </div>
</div>

<script>
    function autoFillPrice(type) {
        const priceInput = document.getElementById('priceInput');
        if (type === 'Standard Bike') {
            priceInput.value = 500;
        } else if (type === 'E-Scooter') {
            priceInput.value = 1500;
        } else {
            priceInput.value = '';
        }
    }
</script>
