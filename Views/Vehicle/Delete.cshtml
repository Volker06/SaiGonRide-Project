@model SaigonRide.Models.Vehicle

@{
    ViewData["Title"] = "Xóa xe";
}

<div class="container py-4" style="max-width: 600px;">
    <h2 class="fw-bold mb-4 text-danger">
        <i class="bi bi-trash3-fill me-2"></i>
        <span data-i18n="vehicle.delete.title">Xác nhận xóa xe</span>
    </h2>

    <div class="alert alert-danger d-flex align-items-center mb-4">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <span data-i18n="vehicle.delete.warning">Bạn có chắc muốn xóa xe này không? Hành động này không thể hoàn tác.</span>
    </div>

    <div class="card shadow border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="text-primary mb-3">
                <i class="bi bi-bicycle me-2"></i>
                <span data-i18n="vehicle.delete.info">Thông tin xe</span>
            </h5>

            <table class="table table-borderless">
                <tr>
                    <td><i class="bi bi-tag-fill text-secondary me-2"></i><strong data-i18n="vehicle.delete.type">Loại xe:</strong></td>
                    <td>@Model.Type</td>
                </tr>
                <tr>
                    <td><i class="bi bi-circle-fill me-2 @(Model.Status == "Available" ? "text-success" : "text-danger")"></i><strong data-i18n="vehicle.delete.status">Trạng thái:</strong></td>
                    <td>
                        @if (Model.Status == "Available")
                        {
                            <span class="badge bg-success" data-i18n="vehicle.status.available">Sẵn sàng</span>
                        }
                        else if (Model.Status == "Rented")
                        {
                            <span class="badge bg-danger" data-i18n="vehicle.status.rented">Đang thuê</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary" data-i18n="vehicle.status.maintenance">@Model.Status</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td><i class="bi bi-currency-dollar text-warning me-2"></i><strong data-i18n="vehicle.delete.price">Giá/phút:</strong></td>
                    <td>@Model.PricePerMinute.ToString("N0") VND</td>
                </tr>
                <tr>
                    <td><i class="bi bi-geo-alt-fill text-danger me-2"></i><strong data-i18n="vehicle.delete.station">Trạm:</strong></td>
                    <td>@(Model.Station?.StationName ?? "Chưa có trạm")</td>
                </tr>
            </table>
        </div>
    </div>

    <div class="d-flex gap-3">
        <form asp-action="Delete" class="flex-fill">
            <input type="hidden" asp-for="VehicleID" />
            <button type="submit" class="btn btn-danger w-100 py-3">
                <i class="bi bi-trash3-fill me-2"></i>
                <span data-i18n="vehicle.delete.btn">Xác nhận xóa</span>
            </button>
        </form>
        <a asp-action="Index" class="btn btn-secondary flex-fill py-3">
            <i class="bi bi-arrow-left-circle me-2"></i>
            <span data-i18n="vehicle.delete.back">Quay lại</span>
        </a>
    </div>
</div>
