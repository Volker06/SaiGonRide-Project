@model SaigonRide.Models.Vehicle

@{
    ViewData["Title"] = "Edit Vehicle";
}

<div class="container py-4" style="max-width: 500px;">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-pencil-square text-warning me-2"></i>
        Chỉnh sửa xe
    </h2>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">
            <form asp-action="Edit">
                <input type="hidden" asp-for="VehicleID" />

                <div class="mb-3">
                    <label class="form-label">
                        <i class="bi bi-bicycle text-primary me-1"></i>
                        <strong>Loại xe</strong>
                    </label>
                    <select name="Type" class="form-select" onchange="autoFillPrice(this.value)">
                        <option value="Standard Bike" selected="@(Model.Type == "Standard Bike")">
                            Standard Bike
                        </option>
                        <option value="E-Scooter" selected="@(Model.Type == "E-Scooter")">
                            E-Scooter
                        </option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="bi bi-circle-fill text-secondary me-1"></i>
                        <strong>Trạng thái</strong>
                    </label>
                    <select name="Status" class="form-select">
                        <option value="Available" selected="@(Model.Status == "Available")">
                            ✅ Available
                        </option>
                        <option value="Rented" selected="@(Model.Status == "Rented")">
                            🟡 Rented
                        </option>
                        <option value="Maintenance" selected="@(Model.Status == "Maintenance")">
                            🔴 Maintenance
                        </option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="bi bi-currency-dollar text-warning me-1"></i>
                        <strong>Giá thuê (VND/phút)</strong>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-cash-coin"></i>
                        </span>
                        <input type="number" name="PricePerMinute" id="priceInput"
                               class="form-control" asp-for="PricePerMinute" />
                        <span class="input-group-text">VND</span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                        <strong>Trạm</strong>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-pin-map-fill"></i>
                        </span>
                        <select name="StationID" class="form-select" asp-items="ViewBag.StationID">
                            <option value="">-- Chọn trạm --</option>
                        </select>
                    </div>
                </div>

                <button type="submit" class="btn btn-warning w-100 py-3 mb-2">
                    <i class="bi bi-floppy-fill me-2"></i>
                    Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-secondary w-100 py-3">
                    <i class="bi bi-arrow-left-circle me-2"></i>
                    Quay lại
                </a>
            </form>
        </div>
    </div>
</div>

<script>
    function autoFillPrice(type) {
        const priceInput = document.getElementById('priceInput');
        if (type === 'Standard Bike') {
            priceInput.value = 500;
        } else if (type === 'E-Scooter') {
            priceInput.value = 1500;
        }
    }
</script>